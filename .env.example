# Copy to .env and fill in. .env is gitignored.

# NCBI E-utilities (PubMed). Optional but raises rate limit 3->10 req/s.
NCBI_API_KEY=
NCBI_EMAIL=ytsimon2004@gmail.com

# Frontier LLMs (only needed if a frontier backend is selected in models.yaml)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Override config paths if desired
SCIREG_MODELS_CONFIG=configs/models.yaml
SCIREG_PIPELINE_CONFIG=configs/pipeline.yaml
